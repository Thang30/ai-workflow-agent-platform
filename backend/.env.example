DATABASE_URL=postgresql://localhost:5432/ai_workflow_agent_platform
HF_TOKEN=replace-with-your-hugging-face-token
MODEL=meta-llama/Llama-3.1-8B-Instruct:cheapest
TAVILY_API_KEY=
SELF_IMPROVEMENT_LOW_SCORE_THRESHOLD=7
SELF_IMPROVEMENT_MAX_RETRIES=1

# Optional CORS overrides
# FRONTEND_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Leave experiments disabled unless you are running one active split.
EXPERIMENT_ENABLED=false

# Model experiment example. Uncomment this block to compare models.
# EXPERIMENT_ENABLED=true
# EXPERIMENT_NAME=model-comparison-apr-2026
# EXPERIMENT_TYPE=model
# EXPERIMENT_VARIANT_A_NAME=A
# EXPERIMENT_VARIANT_A_MODEL=meta-llama/Llama-3.1-8B-Instruct:cheapest
# EXPERIMENT_VARIANT_B_NAME=B
# EXPERIMENT_VARIANT_B_MODEL=openai/gpt-oss-120b:cerebras

# Planner prompt experiment example. Prompt file paths are resolved relative to backend/.
# EXPERIMENT_ENABLED=true
# EXPERIMENT_NAME=planner-prompt-apr-2026
# EXPERIMENT_TYPE=prompt
# EXPERIMENT_VARIANT_A_NAME=A
# EXPERIMENT_VARIANT_A_PLANNER_PROMPT_FILE=prompts/experiments/planner-variant-a.txt
# EXPERIMENT_VARIANT_B_NAME=B
# EXPERIMENT_VARIANT_B_PLANNER_PROMPT_FILE=prompts/experiments/planner-variant-b.txt

# Inline planner prompt env vars still work, but prompt files are easier to review and diff.
# EXPERIMENT_VARIANT_A_PLANNER_PROMPT=You are a planning agent.\nUser request:\n$query\n$retry_guidance
# EXPERIMENT_VARIANT_B_PLANNER_PROMPT=You are a planning agent.\nUser request:\n$query\n$retry_guidanceHF_TOKEN=
MODEL=
TAVILY_API_KEY=
DATABASE_URL=
